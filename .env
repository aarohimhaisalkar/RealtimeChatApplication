# Real-Time Chat Application Environment Variables
# IMPORTANT: Never commit this file to version control!

# JWT Secret Key - Generate a strong random key for production
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=a3f8b2c1d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0

# Database URL (default: SQLite for development)
DATABASE_URL=sqlite:///./chat.db

# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
